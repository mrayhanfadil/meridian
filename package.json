{
  "name": "dlmm-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Autonomous DLMM LP agent for Meteora on Solana",
  "main": "index.js",
  "bin": {
    "meridian": "cli.js"
  },
  "scripts": {
    "setup": "npx tsx setup.js",
    "env:encrypt": "node scripts/envrypt.js encrypt",
    "start": "npx tsx index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart meridian --update-env",
    "pm2:logs": "pm2 logs meridian --lines 100",
    "pm2:stop": "pm2 stop meridian",
    "pm2:delete": "pm2 delete meridian",
    "dev": "DRY_RUN=true npx tsx index.js",
    "lb:check": "node plugins/lb/install.mjs --check",
    "lb:install": "node plugins/lb/install.mjs",
    "lb:force": "node plugins/lb/install.mjs --force",
    "lb:revert": "node plugins/lb/install.mjs --revert",
    "test": "npm run test:syntax",
    "test:syntax": "find . -path ./node_modules -prune -o -name '*.js' -exec node --check {} \\;",
    "test:screen": "node test/test-screening.js",
    "test:agent": "DRY_RUN=true node test/test-agent.js",
    "postinstall": "node scripts/patch-anchor.js"
  },
  "knip": {
    "ignore": [
      "discord-listener/**"
    ]
  },
  "dependencies": {
    "@meteora-ag/dlmm": "1.9.4",
    "@solana/web3.js": "^1.95.0",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "dotenv": "^17.3.1",
    "jsonrepair": "^3.13.3",
    "node-cron": "^3.0.3",
    "openai": "^4.73.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
